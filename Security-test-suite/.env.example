# =============================================================================
# Security Test Suite — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed.
# NEVER commit the .env file — it is git-ignored.
# =============================================================================

# Juice Shop
JUICE_SHOP_URL=http://localhost:3000
JUICE_SHOP_VERSION=latest

# ZAP Proxy
ZAP_API_KEY=change-me-to-random-string
ZAP_PROXY_URL=http://localhost:8080

# Test Configuration
TEST_ADMIN_EMAIL=admin@juice-sh.op
TEST_ADMIN_PASSWORD=admin123
TEST_TIMEOUT=30
TEST_RETRY_COUNT=2

# Reporting
REPORT_DIR=reports
HTML_REPORT=true
